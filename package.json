{
	"name": "nuqs-storybook-adapter",
	"version": "0.1.0",
	"description": "Nuqs v2 adapter compatible with @storybook/nextjs-vite mock router",
	"homepage": "https://github.com/shawngustaw/nuqs-storybook-adapter#readme",
	"bugs": {
		"url": "https://github.com/shawngustaw/nuqs-storybook-adapter/issues"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/shawngustaw/nuqs-storybook-adapter.git"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			}
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "bunup",
		"dev": "bunup --watch",
		"format": "oxfmt",
		"lint": "oxlint",
		"prepare": "bun simple-git-hooks",
		"release": "bumpp --commit --push --tag",
		"test": "bun test",
		"test:coverage": "bun test --coverage",
		"test:watch": "bun test --watch",
		"type-check": "tsc --noEmit"
	},
	"devDependencies": {
		"@types/bun": "^1.3.11",
		"bumpp": "^11.0.1",
		"bunup": "^0.16.31",
		"next": "^16.2.2",
		"nuqs": "^2.8.9",
		"oxfmt": "^0.44.0",
		"oxlint": "^1.59.0",
		"simple-git-hooks": "^2.13.1",
		"typescript": "^6.0.2"
	},
	"peerDependencies": {
		"next": ">=13.0.0",
		"nuqs": ">=2.0.0",
		"typescript": ">=4.5.0"
	},
	"peerDependenciesMeta": {
		"typescript": {
			"optional": true
		}
	},
	"simple-git-hooks": {
		"pre-commit": "bun run lint && bun run type-check"
	}
}
